@using WebApp.Models.TodoLists
@model TodoListWebApiModel

@{
    ViewData["Title"] = "Todo List Details";
    bool canEdit = Model.CanEdit;
}

<h2>@Model.Title</h2>

<p>@Model.Description</p>

@if (Model.Tasks != null && Model.Tasks.Any())
{
    <h4>Tasks</h4>
    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
                <th>Assignee</th>
                @if (canEdit)
                {
                    <th style="width: 150px;">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var task in Model.Tasks)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Description</td>
                    <td>
                        <span class="badge @GetStatusBadgeClass(task.Status)">
                            @task.Status
                        </span>
                    </td>
                    <td>@task?.Assignee?.UserName</td>

                    @if (canEdit)
                    {
                        <td>
                            <a asp-controller="Task" asp-action="Edit" asp-route-id="@task?.Id"
                               class="btn btn-sm btn-outline-primary me-2">✎ Edit</a>

                            <form asp-controller="Task" asp-action="Delete" asp-route-id="@task?.Id"
                                  method="post" class="d-inline">
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this task?');">
                                    &times; Delete
                                </button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No tasks in this list.</p>
}

@if (canEdit)
{
    <div class="mt-3">
        <a asp-controller="Task" asp-action="Add" asp-route-todoListId="@Model.Id"
           class="btn btn-success">Add Task</a>
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@functions {
    private string GetStatusBadgeClass(Core.Enums.TaskStatus status)
    {
        return status switch
        {
            Core.Enums.TaskStatus.NotStarted => "bg-secondary",
            Core.Enums.TaskStatus.InProgress => "bg-warning text-dark",
            Core.Enums.TaskStatus.Completed => "bg-success",
            _ => "bg-dark"
        };
    }
}
