@model IEnumerable<WebApp.Models.Tasks.TaskWebApiModel>

@{
    ViewData["Title"] = "All Tasks";
    var now = DateTime.UtcNow.ToLocalTime();
}

<h2 class="mb-4">All Tasks</h2>

<form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
    <div class="col-md-4">
        <label for="searchTitle" class="form-label fw-semibold">Search by Title</label>
        <input type="text" name="searchTitle" value="@ViewBag.SearchTitle" class="form-control" placeholder="Task title..." />
    </div>

    <div class="col-md-3">
        <label for="createdRange" class="form-label fw-semibold">Created Within</label>
        <select name="createdRange" class="form-select">
            <option value="today" selected="@(ViewBag.CreatedRange == "today")">Today</option>
            <option value="week" selected="@(ViewBag.CreatedRange == "week")">Last 7 Days</option>
            <option value="month" selected="@(ViewBag.CreatedRange == "month")">Last 30 Days</option>
            <option value="year" selected="@(ViewBag.CreatedRange == "year")">Last Year</option>
            <option value="all" selected="@(ViewBag.CreatedRange == "all")">All Time</option>
        </select>
    </div>

    <div class="col-md-3">
        <label for="dueFilter" class="form-label fw-semibold">Due Filter</label>
        <select name="dueFilter" class="form-select">
            <option value="overdue" selected="@(ViewBag.DueFilter == "overdue")">Already Overdue</option>
            <option value="day" selected="@(ViewBag.DueFilter == "day")">Due in 1 Day</option>
            <option value="week" selected="@(ViewBag.DueFilter == "week")">Due in 7 Days</option>
            <option value="month" selected="@(ViewBag.DueFilter == "month")">Due in 30 Days</option>
            <option value="year" selected="@(ViewBag.DueFilter == "year")">Due in 1 Year</option>
            <option value="all" selected="@(ViewBag.DueFilter == "all")">All</option>
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Search</button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-2 g-4">
@foreach (var task in Model)
{
    bool isOverdue = task.DueDate.ToLocalTime() < now && task.Status != Core.Enums.TaskStatus.Completed;

        <div class="col">
            <div class="card h-100 rounded-3 shadow-sm border-2 @(isOverdue ? "border-danger" : "")">
                <div class="card-body">
                    <h5 class="card-title mb-2 fw-semibold">
                        <a asp-action="Details" asp-route-id="@task.Id" class="text-decoration-none text-dark">
                            @task.Title
                        </a>
                        @if (isOverdue)
                        {
                            <span class="badge bg-danger ms-2">Expired</span>
                        }
                    </h5>

                    <p class="text-muted mb-2">@task.Description</p>

                    <p class="mb-1">
                        👤 <strong>Assignee:</strong>
                        @(string.IsNullOrEmpty(task.Assignee?.UserName) ? "—" : task.Assignee.UserName)
                    </p>

                    <div class="d-flex justify-content-between small text-muted mb-2">
                        <span>🗓 Created: @task.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                        <span>⏰ Due: @task.DueDate.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                    </div>

                    <div class="d-flex gap-2">
                        @if (task.CanEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@task.Id" method="post" class="d-inline">
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>

                        }
                        else if (task.IsAssignee)
                        {
                            <form asp-action="ChangeStatus" asp-route-id="@task.Id" method="post" class="d-inline-block position-relative">
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                @Html.AntiForgeryToken()
                                <button type="button"
                                        class="badge @GetStatusBadgeClass(task.Status)"
                                        onclick="this.nextElementSibling.classList.toggle('d-none')"
                                        style="cursor:pointer;">
                                    @task.Status
                                </button>

                                <div class="position-absolute mt-1 d-none" style="z-index:1000;">
                                    @foreach (Core.Enums.TaskStatus s in Enum.GetValues(typeof(Core.Enums.TaskStatus)))
                                    {
                                        @if (s != task.Status)
                                        {
                                            <button type="submit" name="newStatus" value="@s"
                                                    class="badge @GetStatusBadgeClass(s) d-block mb-1"
                                                    style="width:100%; text-align:left; border:none; cursor:pointer;">
                                                @s
                                            </button>
                                        }
                                    }
                                </div>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Read-only</span>
                        }
                        <a asp-action="Details" asp-route-id="@task.Id" class="btn btn-sm btn-outline-secondary">Details</a>

                    </div>
                </div>
            </div>
        </div>
}
</div>

@functions {
    private string GetStatusBadgeClass(Core.Enums.TaskStatus status)
    {
        return status switch
        {
            Core.Enums.TaskStatus.NotStarted => "bg-secondary",
            Core.Enums.TaskStatus.InProgress => "bg-warning text-dark",
            Core.Enums.TaskStatus.Completed => "bg-success",
            _ => "bg-dark"
        };
    }
}
