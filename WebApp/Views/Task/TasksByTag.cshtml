@using WebApp.Models.Tasks
@model IEnumerable<TaskWebApiModel>
@{
    var tagName = Context.Request.Query["tagName"];
    ViewData["Title"] = $"Tasks tagged with '{tagName}'";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Tasks tagged with “@tagName”</h2>
    <a asp-controller="Tag" asp-action="Index" class="btn btn-secondary">
        ← Back to all tags
    </a>
</div>
@if (!Model.Any())
{
    <div class="alert alert-warning">No tasks found with this tag.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var task in Model)
        {
            <div class="col">
                <a asp-action="Details" asp-route-id="@task.Id" class="text-decoration-none text-dark">
                    <div class="card h-100 rounded-3 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-semibold">@task.Title</h5>
                            <p class="text-muted mb-2">@task.Description</p>

                            <div class="d-flex justify-content-between small text-muted">
                                <span>🗓 Created: @task.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                                <span>⏰ Due: @task.DueDate.ToLocalTime().ToString("dd MMM yyyy")</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
