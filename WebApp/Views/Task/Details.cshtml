@model WebApp.Models.Tasks.TaskWebApiModel

@{
    ViewData["Title"] = $"Task Details - {Model.Title}";
}

<div class="card shadow-sm border-2 mt-4">
    <div class="card-body">
        <h3 class="card-title mb-3">@Model.Title</h3>

        <p class="text-muted">@Model.Description</p>

        <dl class="row">
            <dt class="col-sm-3">Status:</dt>
            <dd class="col-sm-9">
                <span class="badge @GetStatusBadgeClass(Model.Status)">@Model.Status</span>
            </dd>

            <dt class="col-sm-3">Created:</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime()</dd>

            <dt class="col-sm-3">Due Date:</dt>
            <dd class="col-sm-9">@Model.DueDate.ToLocalTime()</dd>

            @if (!string.IsNullOrEmpty(Model.AssigneeName))
            {
                <dt class="col-sm-3">Assignee:</dt>
                <dd class="col-sm-9">@Model.AssigneeName</dd>
            }

            @if (Model.Tags != null && Model.Tags.Any())
            {
                <dt class="col-sm-3">Tags:</dt>
                <dd class="col-sm-9">
                    @foreach (var tag in Model.Tags)
                    {
                        <span class="badge bg-info text-dark me-1">@tag.Name</span>
                    }
                </dd>
            }
        </dl>

        <a asp-action="Index" class="btn btn-secondary">← Back to list</a>
    </div>
</div>

@functions {
    private string GetStatusBadgeClass(Core.Enums.TaskStatus status)
    {
        return status switch
        {
            Core.Enums.TaskStatus.NotStarted => "bg-secondary",
            Core.Enums.TaskStatus.InProgress => "bg-warning text-dark",
            Core.Enums.TaskStatus.Completed => "bg-success",
            _ => "bg-dark"
        };
    }
}
