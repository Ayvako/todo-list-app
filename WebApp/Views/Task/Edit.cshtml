@using WebApp.Models.Tasks
@model TaskEditModel
@{
    var returnUrl = Context.Request.Headers["Referer"].ToString();
}
<h2>Edit Task</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label for="Title" class="form-label">Title</label>
        <input id="Title" name="Title" class="form-control" value="@Model.Title" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="Description" class="form-label">Description</label>
        <textarea id="Description" name="Description" class="form-control">@Model.Description</textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="DueDate" class="form-label">Due Date</label>
        <input id="DueDate" name="DueDate" type="date" class="form-control" value="@Model.DueDate.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="Status" class="form-label">Status</label>
        <select id="Status" name="Status" class="form-select">
            <option value="NotStarted" selected="@(Model.Status == Core.Enums.TaskStatus.NotStarted)">Not Started</option>
            <option value="InProgress" selected="@(Model.Status == Core.Enums.TaskStatus.InProgress)">In Progress</option>
            <option value="Completed" selected="@(Model.Status == Core.Enums.TaskStatus.Completed)">Completed</option>
        </select>
    </div>

    <div class="mb-3">
        <label for="AssigneeName" class="form-label">Assignee</label>
        <input id="AssigneeName" name="AssigneeName" class="form-control" value="@Model.AssigneeName" />
        <span asp-validation-for="AssigneeName" class="text-danger"></span>
    </div>


    <button type="submit" class="btn btn-primary">Save</button>
    <a href="@returnUrl" class="btn btn-secondary">Cancel</a>

</form>

<div class="mb-3">

    @if (Model.Tags != null && Model.Tags.Any())
    {
        <h6 class="form-label">Tags</h6>

        <ul class="list-inline">
            @foreach (var tag in Model.Tags)
            {
                <li class="list-inline-item">
                    <span class="badge bg-info text-dark">
                        @tag.Name
                        <form asp-controller="Tag" asp-action="RemoveTag" method="post" class="d-inline">
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="taskId" value="@Model.Id" />
                            <input type="hidden" name="Name" value="@tag.Name" />
                            <button type="submit" class="btn-close btn-close-white ms-1" aria-label="Remove"></button>
                        </form>
                    </span>
                </li>
            }
        </ul>
    }

    <form asp-controller="Tag" asp-action="AddTag" method="post" class="d-flex mt-2">
        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
        @Html.AntiForgeryToken()
        <input type="hidden" name="taskId" value="@Model.Id" />
        <input name="Name" class="form-control me-2" placeholder="Enter tag name" />
        <button type="submit" class="btn btn-outline-primary">Add</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
